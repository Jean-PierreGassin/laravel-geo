{
    "name": "jeanpierregassin/laravel-geo",
    "description": "Generative Engine Optimization (GEO) for Laravel: llms.txt, JSON-LD structured data, and AI crawler tooling.",
    "keywords": [
        "laravel",
        "geo",
        "generative-engine-optimization",
        "llms-txt",
        "ai",
        "seo"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Jean-Pierre Gassin",
            "email": "jeanpierre.gassin@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^11.0 || ^12.0",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "JeanPierreGassin\\LaravelGeo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JeanPierreGassin\\LaravelGeo\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JeanPierreGassin\\LaravelGeo\\GeoServiceProvider"
            ],
            "aliases": {
                "Geo": "JeanPierreGassin\\LaravelGeo\\Facades\\Geo"
            }
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "check-style": "phpcs -p -s --cache",
        "fix-style": "phpcbf -p -s"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
